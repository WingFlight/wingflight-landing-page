<FilesMatch "\.(txt|log|bin|hex|elf|json|md|gitignore|xml|lock|bat)$">
    Require all denied
</FilesMatch>

<FilesMatch "\.(html|htm|svg|css|js)$">
    Require all granted
</FilesMatch>

<Files "index.php">
    Require all granted
</Files>
<Files "admin.php">
    Require all granted
</Files>

RewriteEngine On
#Activate to force https.
RewriteCond %{HTTPS} off
RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [R,L]

RewriteCond %{HTTP:Authorization} ^(.*)
RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]

RewriteBase /iot/
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.+)$ index.php [QSA,L]